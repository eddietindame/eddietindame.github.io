{
  "name": "eddietindame.github.io",
  "version": "2.1.0",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build && touch ./out/.nojekyll",
    "build:serve": "pnpm build && pnpm serve",
    "serve": "serve -p 8080 ./out",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prod": "next build && next start -p 3001",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.9",
    "@bprogress/next": "^3.2.6",
    "@madeinhaus/nextjs-page-transition": "^4.2.0",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.2.1",
    "@next/third-parties": "^15.2.1",
    "@types/mdx": "^2.0.13",
    "bootstrap": "^5.3.3",
    "next": "15.2.1",
    "next-mdx-remote": "^5.0.0",
    "prop-types": "^15.8.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-image": "^4.1.0",
    "react-lazyload": "^3.2.1",
    "react-scrollchor": "^6.0.0",
    "react-spring": "^9.7.5",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.0.12",
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.10",
    "@types/react-lazyload": "^3.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sass": "^1.85.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.0.12",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,css,scss}": [
      "prettier --write"
    ]
  }
}
